    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
